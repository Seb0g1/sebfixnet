# === InetFix Configuration ===
# Copy to .env and fill in your values

API_SECRET=change-me-to-random-secret-32chars
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
API_BASE_URL=https://fixnet.sebog1.ru
BOT_TOKEN=

# Admin panel
ADMIN_PASSWORD=change-me-admin-password
SITE_URL=https://fixnet.sebog1.ru
FORWARD_CHANNEL=seb0g1site
FORWARD_ENABLED=true

# 3x-ui panel
XUI_PANEL_URL=https://bot.sebog1.ru/xbNquwImId
XUI_USERNAME=your-panel-login
XUI_PASSWORD=your-panel-password
XUI_INBOUND_ID=1
XUI_ENABLED=true

# VLESS REALITY (filled automatically from 3x-ui inbound)
VLESS_SERVER=bot.sebog1.ru
VLESS_PORT=8443
VLESS_SNI=www.amazon.com
VLESS_PUBLIC_KEY=
VLESS_SHORT_ID=
VLESS_FLOW=xtls-rprx-vision

# App branding
APP_NAME=Fixnet
APP_AUTHOR=Seb0g1
DOWNLOAD_URL=https://fixnet.sebog1.ru/api/v1/download
SUPPORT_USERNAME=Seb0g1
CHANNEL_USERNAME=inetfix_news

KEY_TTL_DAYS=30
KEY_RATE_LIMIT_HOURS=24
