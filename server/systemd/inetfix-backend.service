[Unit]
Description=InetFix Backend API
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/inetfix/backend
EnvironmentFile=/opt/inetfix/.env
ExecStart=/opt/inetfix/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
