[Unit]
Description=Fixnet Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/sebfixnet/backend
EnvironmentFile=/opt/sebfixnet/.env
ExecStart=/opt/sebfixnet/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
