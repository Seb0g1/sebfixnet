{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InetFix",
  "version": "1.0.0",
  "identifier": "com.seb0g1.inetfix",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InetFix (By Seb0g1)",
        "width": 480,
        "height": 680,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "externalBin": [
      "binaries/sing-box"
    ],
    "resources": [
      "binaries/*"
    ]
  },
  "plugins": {}
}
